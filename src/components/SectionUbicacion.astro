<section id="contacto" class="ubicacion">
  <div class="ubicacion__container">
    <p class="ubicacion__eyebrow">UBICACIÓN</p>
    <h2 class="ubicacion__heading" data-reveal>Visítanos</h2>

    <div class="ubicacion__grid">
      <!-- Info column -->
      <div class="ubicacion__info" data-reveal="left">

        <!-- Dirección -->
        <div class="info-block">
          <div class="info-block__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <h3 class="info-block__title">Dirección</h3>
            <p class="info-block__text">
              Prol. Gral. Ignacio Zaragoza 501, Valle de las Trojes<br/>
              20908 Aguascalientes, Ags.
            </p>
          </div>
        </div>

        <!-- Horarios -->
        <div class="info-block">
          <div class="info-block__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <h3 class="info-block__title">Horarios</h3>
            <table class="horario-table" aria-label="Horarios de atención">
              <tbody>
                <tr>
                  <td class="horario-table__day">Mar – Dom</td>
                  <td class="horario-table__hours">3:00 PM – 11:00 PM</td>
                </tr>
                <tr>
                  <td class="horario-table__day">Lunes</td>
                  <td class="horario-table__hours">Cerrado</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Contacto -->
        <div class="info-block">
          <div class="info-block__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.74a16 16 0 0 0 6.29 6.29l.93-.93a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/>
            </svg>
          </div>
          <div>
            <h3 class="info-block__title">Contacto</h3>
            <p class="info-block__text">
              <a href="tel:+524493896785" class="info-block__link">+52 449 389 6785</a>
            </p>
            <a
              href="https://wa.me/524493896785?text=Hola%2C%20me%20gustar%C3%ADa%20hacer%20una%20reservaci%C3%B3n"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--brand-green ubicacion__wa-btn"
              aria-label="Contactar por WhatsApp"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/>
              </svg>
              Escribir por WhatsApp
            </a>
          </div>
        </div>

        <!-- Redes Sociales -->
        <div class="info-block">
          <div class="info-block__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </div>
          <div>
            <h3 class="info-block__title">Síguenos</h3>
            <div class="social-links">
              <a
                href="https://www.facebook.com/p/La-Hidroc%C3%A1lida-pozoleria-61574562187467/"
                target="_blank"
                rel="noopener noreferrer"
                class="social-link social-link--facebook"
                aria-label="Facebook de La Hidrocálida Pozolería"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </a>
              <a
                href="https://www.instagram.com/la_hidrocalida_pozoleria/"
                target="_blank"
                rel="noopener noreferrer"
                class="social-link social-link--instagram"
                aria-label="Instagram de La Hidrocálida Pozolería"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
                Instagram
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Map column -->
      <div class="ubicacion__map-wrap" data-reveal="right">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3700.240375791656!2d-102.3108874!3d21.947404!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8429ef001128a11b%3A0x90d5433c9bb67788!2sLa%20Hidrocalida%20Pozoleria!5e0!3m2!1ses!2smx!4v1718873000000!5m2!1ses!2smx"
          class="ubicacion__map"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de La Hidrocálida Pozolería en Aguascalientes"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
.ubicacion {
  background: var(--color-cream-02);
  padding: var(--space-3xl) var(--space-xl);
}

.ubicacion__container {
  max-width: 1200px;
  margin: 0 auto;
}

.ubicacion__eyebrow {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-yellow);
  margin-bottom: var(--space-sm);
}

.ubicacion__heading {
  font-family: var(--font-display);
  font-size: clamp(1.875rem, 3.5vw, 2.75rem);
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: var(--space-2xl);
  line-height: 1.15;
}

.ubicacion__grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: var(--space-2xl);
  align-items: start;
}

/* Info blocks */
.ubicacion__info {
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
}

.info-block {
  display: flex;
  gap: var(--space-md);
  align-items: flex-start;
}

.info-block__icon {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  background: var(--color-navy);
  color: var(--color-white);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
}

.info-block__title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: var(--space-xs);
}

.info-block__text {
  font-size: 0.9375rem;
  color: var(--color-ink-60);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
}

.info-block__link {
  color: var(--color-navy);
  font-weight: 500;
  transition: opacity var(--transition);
}

.info-block__link:hover {
  opacity: 0.7;
}

/* Horario table */
.horario-table {
  border-collapse: collapse;
  margin-top: 4px;
}

.horario-table__day {
  font-size: 0.875rem;
  color: var(--color-ink-60);
  padding-right: var(--space-lg);
  padding-bottom: 4px;
  font-weight: 500;
}

.horario-table__hours {
  font-size: 0.875rem;
  color: var(--color-navy);
  font-weight: 600;
  padding-bottom: 4px;
}

/* WhatsApp button */
.ubicacion__wa-btn {
  margin-top: var(--space-md);
  font-size: 0.875rem;
  padding: 0.6rem 1.25rem;
}

/* Social links */
.social-links {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
  flex-wrap: wrap;
}

.social-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-navy);
  padding: 0.5rem 0.875rem;
  border-radius: var(--radius-md);
  background: var(--color-white);
  border: 1px solid rgba(200, 151, 26, 0.15);
  transition: all var(--transition);
  text-decoration: none;
}

.social-link:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-sm);
  border-color: var(--color-yellow);
  color: var(--color-yellow);
}

.social-link svg {
  flex-shrink: 0;
}

/* Map */
.ubicacion__map-wrap {
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.ubicacion__map {
  display: block;
  width: 100%;
  height: 450px;
  border: 0;
}

/* Mobile */
@media (max-width: 768px) {
  .ubicacion {
    padding: var(--space-2xl) var(--space-md);
  }

  .ubicacion__grid {
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .ubicacion__map {
    height: 300px;
  }
}
</style>
