---
import NavbarMobile from './vue/NavbarMobile.vue';
---

<header class="navbar" id="navbar">
  <!-- Logo -->
  <a href="/" class="navbar__logo" aria-label="La Hidrocálida Pozolería — Inicio">
    <img
      src="/real-images/Logo.webp"
      alt="La Hidrocálida Pozolería"
      class="navbar__logo-img"
      height="48"
      width="auto"
    />
  </a>

  <!-- Desktop Nav -->
  <nav class="navbar__links" aria-label="Navegación principal">
    <ul>
      <li><a href="#menu" class="navbar__link">Menú</a></li>
      <li><a href="#nosotros" class="navbar__link">Nosotros</a></li>
      <li><a href="#reviews" class="navbar__link">Reseñas</a></li>
      <li><a href="#contacto" class="navbar__link">Contacto</a></li>
    </ul>
  </nav>

  <!-- Desktop CTAs -->
  <div class="navbar__ctas">
    <a
      href="https://wa.me/524493896785"
      target="_blank"
      rel="noopener noreferrer"
      class="navbar__wa"
      aria-label="Ordenar por WhatsApp"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/>
      </svg>
      WhatsApp
    </a>

    <!-- Uber Eats pill -->
    <a
      href="https://www.ubereats.com/mx/store/la-hidrocalida-pozoleria/hLgLN0ETUVK5xojJ6Qo8iw"
      target="_blank"
      rel="noopener noreferrer"
      class="navbar__ue"
      aria-label="Ordenar en Uber Eats"
    >
      Uber <strong>Eats</strong>
    </a>

    <a href="#contacto" class="btn btn--brand-green navbar__reserve" id="navbar-reserve-btn">
      Reservar
    </a>
  </div>

  <!-- Mobile -->
  <NavbarMobile client:load />
</header>

<style>
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 90;
  display: flex;
  align-items: center;
  gap: var(--space-xl);
  padding: var(--space-md) var(--space-xl);
  transition: box-shadow var(--transition);
}

/* The glass background + blur live on a pseudo-element so the .navbar itself
   does NOT create a containing block (backdrop-filter would), which used to
   trap the fixed mobile drawer/overlay inside the navbar's height. */
.navbar::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: -1;
  background: rgba(250, 244, 232, 0.75);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-bottom: 1px solid rgba(200, 151, 26, 0.12);
  transition: background var(--transition);
}

.navbar.scrolled::before {
  background: rgba(250, 244, 232, 0.95);
}

.navbar.scrolled {
  box-shadow: var(--shadow-sm);
}

/* Logo */
.navbar__logo {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  transition: opacity var(--transition);
}

.navbar__logo:hover {
  opacity: 0.85;
}

.navbar__logo-img {
  height: 48px;
  width: auto;
  object-fit: contain;
  display: block;
}

/* Desktop links */
.navbar__links {
  flex: 1;
}

.navbar__links ul {
  list-style: none;
  display: flex;
  gap: var(--space-xl);
}

.navbar__link {
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-ink);
  position: relative;
  padding-bottom: 2px;
  transition: color var(--transition);
}

.navbar__link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--color-pozole);
  border-radius: 2px;
  transition: width var(--transition);
}

.navbar__link:hover {
  color: var(--color-pozole);
}

.navbar__link:hover::after {
  width: 100%;
}

/* Desktop CTAs */
.navbar__ctas {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.navbar__wa {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.875rem;
  font-weight: 500;
  color: #25D366;
  transition: opacity var(--transition);
}

.navbar__wa:hover {
  opacity: 0.75;
}

/* Uber Eats pill */
.navbar__ue {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  background: #ffffff;
  border: 1px solid var(--color-ink-30);
  padding: 0.4rem 0.875rem;
  border-radius: var(--radius-full);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-ink);
  transition: box-shadow var(--transition), border-color var(--transition);
}

.navbar__ue strong {
  color: #06C167;
  font-weight: 700;
}

.navbar__ue:hover {
  box-shadow: var(--shadow-sm);
  border-color: var(--color-ink-60);
}

.navbar__reserve {
  padding: 0.5rem 1.25rem;
  font-size: 0.875rem;
}

/* Breakpoints */
@media (max-width: 768px) {
  .navbar__links,
  .navbar__ctas {
    display: none;
  }

  .navbar {
    justify-content: space-between;
    padding-inline: var(--space-md);
  }

  /* Push the hamburger to the far right (logo stays left). */
  :global(.navbar-mobile) {
    margin-left: auto;
  }
}

@media (min-width: 769px) {
  :global(.navbar-mobile) {
    display: none;
  }
}
</style>

<script>
  const navbar = document.getElementById('navbar');
  const observer = new IntersectionObserver(
    ([entry]) => {
      navbar?.classList.toggle('scrolled', !entry.isIntersecting);
    },
    { rootMargin: '-80px 0px 0px 0px', threshold: 0 }
  );

  const sentinel = document.createElement('div');
  sentinel.style.cssText = 'position:absolute;top:80px;left:0;width:1px;height:1px;pointer-events:none;';
  document.body.prepend(sentinel);
  observer.observe(sentinel);
</script>
