---
const platillos = [
  {
    nombre: 'Pozole Verde',
    descripcion: 'Caldo verde de maíz cacahuazintle, puerco o pollo. Incluye lechuga, orégano, limón, rábano, cebolla, tostadas y salsas.',
    alt: 'Pozole verde con guarniciones',
    // TODO: foto real
  },
  {
    nombre: 'Pozole Blanco',
    descripcion: 'Caldo blanco tradicional con maíz cacahuazintle, puerco o pollo, y todas las guarniciones de la casa.',
    alt: 'Pozole blanco con guarniciones',
    // TODO: foto real
  },
  {
    nombre: 'Pozole Rojo',
    descripcion: 'Caldo rojo de chile guajillo, maíz cacahuazintle y carne de cerdo o pollo. La receta de siempre.',
    img: '/real-images/PozoleRojo2.webp',
    alt: 'Bowl de pozole rojo con rábano, repollo y tostadas',
  },
  {
    nombre: 'Flautas',
    descripcion: 'Orden de 5, de puerco o pollo. Con queso, crema, lechuga, zanahorias curtidas y salsa de jitomate.',
    alt: 'Orden de flautas doradas',
    // TODO: foto real
  },
  {
    nombre: 'Tacos Dorados',
    descripcion: 'Orden de 6 taquitos de papa con queso. Zanahoria curtida, crema, lechuga y salsa de jitomate.',
    alt: 'Tacos dorados crujientes con guarniciones',
    // TODO: foto real
  },
  {
    nombre: 'Sopes',
    descripcion: 'Orden de 3 sobre cama de frijoles refritos. Surtido de puerco, pollo o chicharrón, con queso y crema.',
    img: '/real-images/sopes.webp',
    alt: 'Orden de sopes con lechuga, queso y salsa',
  },
  {
    nombre: 'Enchiladas Rojas',
    descripcion: 'Orden de 4, relleno a elección. Con queso, crema, lechuga y cueritos.',
    img: '/real-images/Enchiladas1.webp',
    alt: 'Enchiladas rojas con crema y queso',
  },
  {
    nombre: 'Tostadas',
    descripcion: 'Orden de 3 tostadas preparadas. Frijoles refritos, zanahoria curtida, queso, crema, lechuga y salsa de jitomate.',
    alt: 'Orden de tostadas preparadas',
    // TODO: foto real
  },
  {
    nombre: 'Tamales Verdes y Rojos',
    descripcion: 'Tamal individual verde o rojo. Solo en fines de semana.',
    alt: 'Tamales verdes y rojos',
    // TODO: foto real
  },
  {
    nombre: 'Agua de Horchata y Jamaica',
    descripcion: 'Aguas frescas preparadas a diario, ligeramente dulces y refrescantes.',
    img: '/real-images/aguas-frescas.webp',
    alt: 'Aguas frescas de horchata y jamaica',
  },
];
---

<section id="menu" class="platillos">
  <div class="platillos__container">
    <p class="eyebrow" data-reveal>MENÚ</p>
    <h2 class="platillos__heading" data-reveal>Nuestros Platillos</h2>
    <p class="platillos__sub" data-reveal>Ingredientes frescos del mercado local, recetas que llevan décadas en nuestra familia.</p>

    <div class="platillos__grid" data-reveal-group>
      {platillos.map((p) => (
        <article class="platillo-card" data-reveal>
          <div class="platillo-card__img-wrap">
            {p.img ? (
              <img
                src={p.img}
                alt={p.alt}
                class="platillo-card__img"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="platillo-card__img--placeholder" role="img" aria-label={p.alt}>
                <span>Foto próximamente</span>
              </div>
            )}
          </div>
          <div class="platillo-card__body">
            <h3 class="platillo-card__nombre">{p.nombre}</h3>
            <p class="platillo-card__desc">{p.descripcion}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.platillos {
  background: var(--color-cream);
  padding: var(--space-3xl) var(--space-xl);
}

.platillos__container {
  max-width: 1200px;
  margin: 0 auto;
}

.eyebrow {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-yellow);
  margin-bottom: var(--space-sm);
}

.platillos__heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: var(--space-md);
  line-height: 1.15;
}

.platillos__sub {
  font-size: 1.0625rem;
  color: var(--color-ink-60);
  max-width: 560px;
  margin-bottom: var(--space-2xl);
  line-height: 1.65;
}

.platillos__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.platillo-card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: transform var(--transition), box-shadow var(--transition);
}

.platillo-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.platillo-card__img-wrap {
  aspect-ratio: 4 / 3;
  overflow: hidden;
}

.platillo-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 400ms var(--ease-out);
}

.platillo-card:hover .platillo-card__img {
  transform: scale(1.04);
}

.platillo-card__body {
  padding: var(--space-lg);
}

.platillo-card__nombre {
  font-family: var(--font-display);
  font-size: 1.1875rem;
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: var(--space-xs);
  line-height: 1.2;
}

.platillo-card__desc {
  font-size: 0.9rem;
  color: var(--color-ink-60);
  font-style: italic;
  line-height: 1.55;
  margin-bottom: var(--space-md);
}

.platillo-card__img--placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, var(--color-cream) 0%, color-mix(in srgb, var(--color-navy) 8%, var(--color-cream)) 100%);
  border-bottom: 1px solid color-mix(in srgb, var(--color-navy) 8%, transparent);
}

.platillo-card__img--placeholder span {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-ink-60);
}

/* Mobile */
@media (max-width: 768px) {
  .platillos {
    padding: var(--space-2xl) var(--space-md);
  }

  .platillos__grid {
    grid-template-columns: 1fr;
  }
}
</style>
