---
const reviews = [
  {
    nombre: 'Mariana Rodríguez',
    ciudad: 'Aguascalientes',
    texto: 'El pozole rojo es exactamente lo que buscaba: caldo profundo, maíz suave y la cantidad justa de picante. Ya van tres visitas este mes y no pienso parar.',
  },
  {
    nombre: 'Carlos Fuentes',
    ciudad: 'Guadalajara',
    texto: 'Vine por trabajo y me llevaré el recuerdo de ese caldo por siempre. Las enchiladas hidrocálidas también son una delicia. Obligatorio si estás en Aguascalientes.',
  },
  {
    nombre: 'Sofía Méndez',
    ciudad: 'Ciudad de México',
    texto: 'Ambiente familiar, atención cálida y una olla de pozole que parece llevar horas a fuego lento. Se nota el cariño en cada detalle.',
  },
  {
    nombre: 'Andrés Castillo',
    ciudad: 'León',
    texto: 'Los tacos dorados me recordaron a los de mi abuela. Crujientes por fuera, jugosos por dentro. El agua de jamaica, perfectamente equilibrada.',
  },
  {
    nombre: 'Valentina Torres',
    ciudad: 'San Luis Potosí',
    texto: 'Pedí el pozole grande para compartir y aun así sobraron ganas de más. Servicio rápido y el personal siempre con una sonrisa. ¡Diez de diez!',
  },
  {
    nombre: 'Ricardo Herrera',
    ciudad: 'Aguascalientes',
    texto: 'Soy cliente desde que abrieron. El sabor nunca cambia y eso es lo que más valoro. Aquí la consistencia es parte de la receta.',
  },
];
---

<section id="reviews" class="reviews" aria-labelledby="reviews-title">
  <div class="reviews__container">
    <header class="section-header">
      <div class="reviews__badge" aria-label="4.9 de 5 estrellas en Google">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="#F5C518" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <strong>4.9</strong>
        <span>en Google Reviews</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
      </div>

      <p class="eyebrow">Opiniones reales</p>
      <h2 id="reviews-title" class="section-title">Lo que dicen nuestros clientes</h2>
    </header>

    <div class="reviews__grid" role="list">
      {reviews.map((r) => (
        <article class="review-card" role="listitem">
          <div class="review-card__stars" aria-label="5 de 5 estrellas">
            {[...Array(5)].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#F5C518" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <blockquote class="review-card__quote">
            <p>"{r.texto}"</p>
          </blockquote>
          <footer class="review-card__author">
            <strong class="review-card__name">{r.nombre}</strong>
            <span class="review-card__city">{r.ciudad}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.reviews {
  background: var(--color-cream-02);
  padding: var(--space-3xl) var(--space-xl);
}

.reviews__container {
  max-width: 1200px;
  margin-inline: auto;
}

.section-header {
  text-align: center;
  margin-bottom: var(--space-2xl);
}

.eyebrow {
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: var(--space-sm);
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.25rem);
  font-weight: 700;
  color: var(--color-brand-navy);
  line-height: 1.1;
}

.reviews__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  background: var(--color-white);
  border-radius: var(--radius-full);
  padding: 0.5rem 1.125rem;
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--space-xl);
  font-size: 0.9375rem;
}

.reviews__badge strong {
  font-weight: 700;
  color: var(--color-ink);
}

.reviews__badge span {
  color: var(--color-ink-60);
  font-size: 0.875rem;
}

.reviews__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-lg);
}

.review-card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  border-left: 4px solid var(--color-brand-navy);
  padding: var(--space-xl);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  transition: box-shadow var(--transition), transform var(--transition);
}

.review-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}

.review-card__stars {
  display: flex;
  gap: 2px;
}

.review-card__quote {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1rem;
  line-height: 1.7;
  color: var(--color-ink);
  flex: 1;
}

.review-card__author {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.review-card__name {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-brand-navy);
}

.review-card__city {
  font-size: 0.8125rem;
  color: var(--color-ink-60);
}

@media (min-width: 640px) {
  .reviews__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .reviews__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 640px) {
  .reviews {
    padding: var(--space-2xl) var(--space-md);
  }
}
</style>
