---
const platillos = [
  {
    nombre: 'Pozole Rojo Tradicional',
    descripcion: 'Caldo de maíz cacahuazintle, chile guajillo y espinazo de cerdo. La receta de siempre.',
    precio: '$89',
    img: '/real-images/PozoleRojo2.jpg',
    alt: 'Bowl de pozole rojo con rábano, repollo y tostadas',
  },
  {
    nombre: 'Pozole Rojo Especial',
    descripcion: 'Versión enriquecida con chicharrón prensado, aguacate y doble porción de caldo.',
    precio: '$109',
    img: '/real-images/PozoleRojo2%20(1).jpg',
    alt: 'Bowl de pozole rojo especial con guarniciones',
  },
  {
    nombre: 'Pozole Rojo Grande',
    descripcion: 'Porción generosa para compartir. Mismo sabor auténtico, más maíz y más carne.',
    precio: '$129',
    img: '/real-images/PozoleRojo3%20(1).jpg',
    alt: 'Pozole rojo porción grande',
  },
  {
    nombre: 'Enchiladas Hidrocálidas',
    descripcion: 'Tortillas bañadas en salsa roja, rellenas de pollo, crema y queso fresco.',
    precio: '$79',
    img: '/real-images/Enchiladas1.jpg',
    alt: 'Enchiladas hidrocálidas con crema y queso',
  },
  {
    nombre: 'Tacos Dorados',
    descripcion: 'Tres tacos crujientes de papa con pollo, lechuga, crema y salsa verde.',
    precio: '$69',
    img: '/real-images/ChatGPT%20Image%20Jun%2021%2C%202025%2C%2007_51_37%20PM.png',
    alt: 'Tacos dorados crujientes con guarniciones',
  },
  {
    nombre: 'Aguas Frescas',
    descripcion: 'Jamaica, horchata o tamarindo. Preparadas a diario con fruta natural.',
    precio: '$35',
    img: '/real-images/ChatGPT%20Image%20Jun%2021%2C%202025%2C%2009_26_58%20PM.png',
    alt: 'Aguas frescas de temporada',
  },
];
---

<section id="menu" class="platillos" aria-labelledby="platillos-title">
  <div class="platillos__container">
    <header class="section-header">
      <p class="eyebrow">Sabores auténticos</p>
      <h2 id="platillos-title" class="section-title">Nuestros Platillos</h2>
      <p class="section-subtitle">Ingredientes frescos, recetas de generación en generación.</p>
    </header>

    <div class="platillos__grid" role="list">
      {platillos.map((p) => (
        <article class="platillo-card" role="listitem">
          <div class="platillo-card__img-wrap">
            <img
              src={p.img}
              alt={p.alt}
              class="platillo-card__img"
              loading="lazy"
              decoding="async"
              width="400"
              height="300"
            />
          </div>
          <div class="platillo-card__body">
            <h3 class="platillo-card__name">{p.nombre}</h3>
            <p class="platillo-card__desc">{p.descripcion}</p>
            <span class="platillo-card__price">{p.precio}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.platillos {
  background: var(--color-cream);
  padding: var(--space-3xl) var(--space-xl);
}

.platillos__container {
  max-width: 1200px;
  margin-inline: auto;
}

.section-header {
  text-align: center;
  margin-bottom: var(--space-2xl);
}

.eyebrow {
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: var(--space-sm);
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.25rem);
  font-weight: 700;
  color: var(--color-brand-navy);
  line-height: 1.1;
  margin-bottom: var(--space-md);
}

.section-subtitle {
  font-size: 1.0625rem;
  color: var(--color-ink-60);
  max-width: 480px;
  margin-inline: auto;
}

.platillos__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-xl);
}

.platillo-card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition), box-shadow var(--transition);
}

.platillo-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}

.platillo-card__img-wrap {
  aspect-ratio: 4 / 3;
  overflow: hidden;
}

.platillo-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 400ms var(--ease-out);
}

.platillo-card:hover .platillo-card__img {
  transform: scale(1.04);
}

.platillo-card__body {
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.platillo-card__name {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-brand-navy);
  line-height: 1.2;
}

.platillo-card__desc {
  font-size: 0.9375rem;
  color: var(--color-ink-60);
  line-height: 1.55;
  flex: 1;
}

.platillo-card__price {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 0.25rem 0.875rem;
  background: var(--color-brand-yellow);
  color: var(--color-brand-navy);
  font-weight: 700;
  font-size: 0.9375rem;
  border-radius: var(--radius-full);
  letter-spacing: 0.01em;
}

@media (min-width: 640px) {
  .platillos__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .platillos__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 640px) {
  .platillos {
    padding: var(--space-2xl) var(--space-md);
  }
}
</style>
