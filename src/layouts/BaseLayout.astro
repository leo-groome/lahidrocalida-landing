---
// BaseLayout.astro — HTML base con SEO y fuentes
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'La Hidrocálida Pozolería — Pozole en Aguascalientes',
  description = 'Pozolería auténtica en Aguascalientes. Disfruta el sabor de la tradición con ingredientes frescos y recetas que saben a hogar. Ordena en línea o visítanos.',
} = Astro.props;

// URL canónica derivada de Astro (usa `site` de astro.config.mjs)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Imagen social absoluta (el binario lo sube un humano después)
const ogImage = 'https://lahidrocalida-landing.vercel.app/og-image.jpg';

// JSON-LD #1 — Restaurant (datos confirmados por el dueño)
const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "La Hidrocálida Pozolería",
  "description": "Pozolería auténtica en Aguascalientes. Pozole verde, blanco y rojo, de puerco o de pollo, además de flautas, tacos dorados, sopes, enchiladas rojas, tostadas, tamales y aguas frescas de horchata y jamaica.",
  "url": "https://lahidrocalida-landing.vercel.app",
  "image": "https://lahidrocalida-landing.vercel.app/og-image.jpg",
  "logo": "https://lahidrocalida-landing.vercel.app/real-images/Logo.webp",
  "telephone": "+524493896785",
  "priceRange": "$$",
  "servesCuisine": ["Mexicana", "Pozole", "Antojitos mexicanos"],
  "address": { "@type": "PostalAddress", "streetAddress": "Prol. Gral. Ignacio Zaragoza 501, Valle de las Trojes", "addressLocality": "Aguascalientes", "addressRegion": "Aguascalientes", "postalCode": "20908", "addressCountry": "MX" },
  "geo": { "@type": "GeoCoordinates", "latitude": 21.947404, "longitude": -102.3108874 },
  "hasMap": "https://maps.app.goo.gl/jad9Vj8nURR46d3j6",
  "openingHoursSpecification": [ { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "15:00", "closes": "23:00" } ],
  "menu": "https://lahidrocalida-landing.vercel.app/#menu",
  "acceptsReservations": "True",
  "sameAs": [ "https://www.facebook.com/p/La-Hidroc%C3%A1lida-pozoleria-61574562187467/", "https://www.instagram.com/la_hidrocalida_pozoleria/", "https://www.ubereats.com/mx/store/la-hidrocalida-pozoleria/hLgLN0ETUVK5xojJ6Qo8iw", "https://maps.app.goo.gl/jad9Vj8nURR46d3j6" ]
};
// TODO: agregar aggregateRating con datos REALES del Google Business Profile cuando se conecte

// JSON-LD #2 — FAQPage (preguntas/respuestas confirmadas)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Dónde está La Hidrocálida Pozolería?", "acceptedAnswer": { "@type": "Answer", "text": "En Prol. Gral. Ignacio Zaragoza 501, Valle de las Trojes, 20908 Aguascalientes, Ags., México." } },
    { "@type": "Question", "name": "¿Cuáles son los horarios?", "acceptedAnswer": { "@type": "Answer", "text": "Martes a domingo de 3:00 PM a 11:00 PM. Lunes cerrado." } },
    { "@type": "Question", "name": "¿Qué venden?", "acceptedAnswer": { "@type": "Answer", "text": "Pozole verde, blanco y rojo, de puerco o de pollo, además de flautas, tacos dorados, sopes, enchiladas rojas, tostadas, tamales (solo fines de semana) y aguas frescas de horchata y jamaica." } },
    { "@type": "Question", "name": "¿De qué carne es el pozole?", "acceptedAnswer": { "@type": "Answer", "text": "Preparamos el pozole de puerco o de pollo, en sus tres variedades: verde, blanco y rojo." } },
    { "@type": "Question", "name": "¿Hacen entregas a domicilio?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, puedes pedir por Uber Eats o hacer tu pedido y reservación por WhatsApp al +52 449 389 6785." } },
    { "@type": "Question", "name": "¿Aceptan reservaciones?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, puedes reservar por WhatsApp al +52 449 389 6785." } },
    { "@type": "Question", "name": "¿Tienen tamales?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, tamales verdes y rojos, disponibles solo los fines de semana." } }
  ]
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1B2C6B" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="La Hidrocálida Pozolería" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: Restaurant + FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Anti-FOUC + reduce-motion: corre antes del paint -->
    <script is:inline>
      (function () {
        var el = document.documentElement;
        el.classList.add('js');
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          el.classList.add('reduce-motion');
        }
      })();
    </script>

    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/scroll-engine';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Anti-FOUC reveals: ocultos solo si hay JS y NO reduce-motion.
     Sin JS o con reduce-motion -> visibles (contrato del scroll-engine). */
  html.js:not(.reduce-motion) [data-reveal] {
    opacity: 0;
    will-change: opacity, transform;
  }
  html.reduce-motion [data-reveal] {
    opacity: 1 !important;
    transform: none !important;
  }
</style>
